# ─────────────────────────────────────────────
# LEONI AI Server — Environment Variables
# ─────────────────────────────────────────────
# 1. Copy this file and rename it to: .env
# 2. Replace the value below with your real Anthropic API key
# 3. Get your key from: https://console.anthropic.com/

ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Change the port (default is 3000)
# PORT=3000
